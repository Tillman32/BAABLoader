# Comma-separated local printer IDs or hostnames (used for tagging)
PRINTERS=p1s-garage,p1s-office

# Directory containing mounted/collected timelapses per printer
# Example: /Volumes/bambu/timelapses
TIMELAPSE_SOURCE_ROOT=/path/to/timelapses

# Local working directory where files are staged before upload
WORK_DIR=./data

# Optional glob extension filter
TIMELAPSE_EXTENSION=.mp4

# Cloudflare R2 S3-compatible settings
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=your-bucket
R2_PREFIX=timelapses

# Optional dry-run to skip uploading
DRY_RUN=true
