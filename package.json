{
  "name": "baabloader",
  "version": "0.1.0",
  "description": "Utility service to collect Bambu Lab timelapses and upload to Cloudflare R2",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "node --test --import tsx/esm 'src/test/**/*.test.ts'"
  },
  "keywords": [
    "bambu-lab",
    "timelapse",
    "cloudflare-r2"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.825.0",
    "@aws-sdk/lib-storage": "^3.825.0",
    "basic-ftp": "^5.3.0",
    "dotenv": "^16.5.0",
    "mqtt": "^5.15.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
